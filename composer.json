{
    "name": "siren/sdk",
    "description": "Official Siren SDK for PHP — affiliate and incentive tracking for any commerce stack.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "siren",
        "affiliate",
        "affiliate-marketing",
        "referral",
        "incentives",
        "rewards",
        "sdk",
        "webhooks",
        "ecommerce",
        "stripe"
    ],
    "homepage": "https://sirenaffiliates.com",
    "support": {
        "issues": "https://github.com/Novatorius/siren-php/issues",
        "source": "https://github.com/Novatorius/siren-php"
    },
    "authors": [
        {
            "name": "Novatorius LLC",
            "homepage": "https://sirenaffiliates.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Siren\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Siren\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
